# Copie este arquivo para ".env" e ajuste os valores.
# NUNCA cometa o arquivo .env real no controle de versão.

NODE_ENV=development
PORT=3000

# Gere um valor longo e aleatório: openssl rand -hex 32
JWT_SECRET=COLOQUE_AQUI_UMA_CHAVE_ALEATORIA_FORTE
JWT_EXPIRES_IN=24h

# Caminho do banco SQLite, relativo à pasta backend/
DB_PATH=../database/tourin.db

# URL pública da API (usada em links de imagens, etc.)
API_URL=http://localhost:3000

# Origens permitidas para CORS, separadas por vírgula.
# Use "*" apenas em desenvolvimento local. Em produção, coloque o domínio real.
# Exemplo: CORS_ORIGIN=https://meusite.com
CORS_ORIGIN=http://localhost:3000
