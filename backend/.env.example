# Copie este arquivo para ".env" e ajuste os valores.
# NUNCA cometa o arquivo .env real no controle de versão.

NODE_ENV=development
PORT=3000

# Gere um valor longo e aleatório, ex: `openssl rand -hex 32`
JWT_SECRET=e23ca20eff81c70be079f0e6fea3e3cf706e5a7fbc0c95bebdf9ff90a79b2fc4
JWT_EXPIRES_IN=24h

# Caminho do banco SQLite, relativo à pasta backend/
DB_PATH=../database/tourin.db

# URL pública da API (usada em links de imagens, etc.)
API_URL=http://localhost:3000

# Origens permitidas para CORS, separadas por vírgula.
# Use "*" apenas em desenvolvimento.
CORS_ORIGIN=*
